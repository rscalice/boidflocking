QMAKE_PRL_TARGET = Qt6FFmpegMediaPluginImpld.lib
QMAKE_PRL_CONFIG = static
QMAKE_PRL_VERSION = 6.10.2
QMAKE_PRL_LIBS = $$[QT_INSTALL_LIBS]/Qt6Multimediad.lib $$[QT_INSTALL_LIBS]/Qt6Guid.lib -ld3d11 -ldxgi -ldxguid -ld3d12 $$[QT_INSTALL_LIBS]/Qt6Networkd.lib $$[QT_INSTALL_LIBS]/Qt6Cored.lib -lmpr -luserenv -lws2_32 -lmf -lmfplat -lmfreadwrite -lmfuuid -lDwmapi -lDxva2 -lwindowsapp avformat.lib avcodec.lib swresample.lib swscale.lib avutil.lib
QMAKE_PRL_LIBS_FOR_CMAKE = $$[QT_INSTALL_LIBS]/Qt6Multimediad.lib;$$[QT_INSTALL_LIBS]/Qt6Guid.lib;-ld3d11;-ldxgi;-ldxguid;-ld3d12;$$[QT_INSTALL_LIBS]/Qt6Networkd.lib;$$[QT_INSTALL_LIBS]/Qt6Cored.lib;-lmpr;-luserenv;-lws2_32;-lmf;-lmfplat;-lmfreadwrite;-lmfuuid;-lDwmapi;-lDxva2;-lwindowsapp;avformat.lib;avcodec.lib;swresample.lib;swscale.lib;avutil.lib
